# ==============================================================================
# File: deploy-cluster-vars.env
# Purpose: Single source of truth for CP4D 5.4.0 Deployment
# ==============================================================================

# 1. Versioning & Components
export VERSION="5.3.1"
export CPD_VERSION="5.3.1"
export CPD_CLI_BINARY="cpd-cli-linux-EE-14.3.1.tgz"
export PATCH_ID="7"
export COMPONENTS="cpd_platform,ccs,datastage_ent"

# 2. Namespaces (Projects)
# The namespace where the operators (controllers) live
export PROJECT_CPD_INST_OPERATORS="cpd-operators"
# The namespace where DataStage and the CP4D control plane live
export PROJECT_CPD_INST_OPERANDS="cpd"

# 3. Storage Classes
export STG_CLASS_BLOCK="ocs-storagecluster-ceph-rbd"
export STG_CLASS_FILE="ocs-storagecluster-cephfs"

# 4. Global Settings
export CLUSTER_PULL_SECRET="ibm-entitlement-key" # Standard name for the IBM registry secret

# 5. Force the CLI to mount the kubeconfig before executing the command
export OLM_UTILS_LAUNCH_ARGS="-v $HOME/.kube/config:/opt/ansible/.kubeconfig:Z"

# 6. CLI Binary and Workspace Paths
export PATH="/home/itzuser/cpd-cli-tool:$PATH"
export CPD_CLI_MANAGE_WORKSPACE="/home/itzuser/cpd-cli-workspace"