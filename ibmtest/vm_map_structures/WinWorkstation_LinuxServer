[
  {
    "name": "workstation",
    "template": "itz-windows2022-std",
    "cpu": 4,
    "memory": 8,
    "rootDiskSize": 300,
    "ports": ["3389/tcp"]
  },
  {
    "name": "server",
    "template": "itz-rhel9-server",
    "cpu": 2,
    "memory": 12,
    "rootDiskSize": 100,
    "secondaryDiskSize": 100,
    "ports": [
      "80/tcp",
      "9080/tcp", 
      "9443/tcp", 
      "50000/tcp"
    ],
    "cloudInit": ["rhel-subscription", "uptycs"],
    "customCloudInit": [
      "dnf install -y java-1.8.0-openjdk-devel gtk2 libffi libgcc libstdc++ tar unzip libXp chkconfig libXft libXtst bc pam.i686 libnsl.i686 libnsl.x86_64 libxcrypt-compat", 
      "firewall-cmd --zone=public --add-port=80/tcp --permanent",
      "firewall-cmd --zone=public --add-port=9080/tcp --permanent",
      "firewall-cmd --zone=public --add-port=9443/tcp --permanent",
      "firewall-cmd --zone=public --add-port=50000/tcp --permanent",
      "firewall-cmd --reload",
      "mkfs.xfs /dev/vdb"
    ],
    "postDeploy": {
      "repository": "git@github.com:itz-content/dm-mettleci-public.git",
      "variables": {
        "nginx_message": "Welcome to Techzone!"
      },
      "play": "ibmtest/main.yml"
  }
}
]